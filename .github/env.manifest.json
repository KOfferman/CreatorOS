{
  "$schema": "./env.manifest.schema.json",
  "description": "Maps CreatorOS env keys to GitHub Actions secrets vs variables (production environment).",
  "sources": [
    "api/.env.local",
    "web/.env.local"
  ],
  "overrideFile": ".github/env.production.local",
  "productionDefaults": {
    "ENVIRONMENT": "production",
    "LOG_LEVEL": "INFO",
    "AUTH_ENABLED": "true",
    "LLM_PROVIDER": "mock",
    "NEXT_PUBLIC_API_BASE_URL": "/api/v1",
    "CORS_ALLOW_ORIGINS": "https://creator-os.vercel.app",
    "OAUTH_REDIRECT_BASE_URL": "https://creator-os.vercel.app/api/v1/integrations/oauth"
  },
  "localOnly": [
    "API_PORT",
    "WEB_PORT",
    "REDIS_HOST",
    "REDIS_PORT",
    "OLLAMA_BASE_URL",
    "OLLAMA_MODEL",
    "MYSQL_ROOT_PASSWORD",
    "MYSQL_USER",
    "MYSQL_PASSWORD",
    "MYSQL_DATABASE",
    "MYSQL_HOST",
    "MYSQL_PORT"
  ],
  "secrets": [
    "AUTH_SECRET",
    "DATABASE_URL",
    "REDIS_URL",
    "CELERY_BROKER_URL",
    "CELERY_RESULT_BACKEND",
    "OPENAI_API_KEY",
    "OPENROUTER_API_KEY",
    "OPENCLAW_GATEWAY_TOKEN",
    "GOOGLE_CLIENT_SECRET",
    "META_CLIENT_SECRET",
    "META_APP_SECRET",
    "INSTAGRAM_CONFIG_SECRET",
    "TIKTOK_CLIENT_SECRET",
    "PINTEREST_APP_SECRET"
  ],
  "variables": [
    "ENVIRONMENT",
    "LOG_LEVEL",
    "AUTH_URL",
    "AUTH_ENABLED",
    "AUTH_JWT_ALGORITHM",
    "AUTH_ACCESS_TOKEN_EXP_MINUTES",
    "API_RATE_LIMIT_PER_MINUTE",
    "CORS_ALLOW_ORIGINS",
    "CORS_ALLOW_METHODS",
    "CORS_ALLOW_HEADERS",
    "CORS_ALLOW_CREDENTIALS",
    "LLM_PROVIDER",
    "OPENAI_MODEL",
    "OPENCLAW_GATEWAY_URL",
    "OPENCLAW_MODEL",
    "OPENROUTER_MODEL",
    "LLM_MODEL",
    "OAUTH_REDIRECT_BASE_URL",
    "GOOGLE_CLIENT_ID",
    "GOOGLE_AUTH_REDIRECT_URI",
    "GOOGLE_REDIRECT_URI",
    "META_CLIENT_ID",
    "META_APP_ID",
    "META_REDIRECT_URI",
    "INSTAGRAM_CONFIG_ID",
    "INSTAGRAM_REDIRECT_URI",
    "TIKTOK_CLIENT_KEY",
    "PINTEREST_APP_ID",
    "NEXT_PUBLIC_API_BASE_URL",
    "NEXT_PUBLIC_CREATOR_USER_ID",
    "CELERY_ENABLE_BEAT",
    "SYSTEM_USER_EMAIL",
    "SYSTEM_USER_NAME"
  ],
  "vercel": {
    "deploySecrets": [
      "AUTH_SECRET",
      "DATABASE_URL",
      "REDIS_URL",
      "CELERY_BROKER_URL",
      "CELERY_RESULT_BACKEND",
      "OPENAI_API_KEY",
      "OPENROUTER_API_KEY",
      "OPENCLAW_GATEWAY_TOKEN",
      "GOOGLE_CLIENT_SECRET",
      "META_CLIENT_SECRET",
      "META_APP_SECRET",
      "INSTAGRAM_CONFIG_SECRET",
      "TIKTOK_CLIENT_SECRET",
      "PINTEREST_APP_SECRET"
    ],
    "deployVariables": [
      "ENVIRONMENT",
      "LOG_LEVEL",
      "AUTH_URL",
      "AUTH_ENABLED",
      "AUTH_JWT_ALGORITHM",
      "AUTH_ACCESS_TOKEN_EXP_MINUTES",
      "API_RATE_LIMIT_PER_MINUTE",
      "CORS_ALLOW_ORIGINS",
      "CORS_ALLOW_METHODS",
      "CORS_ALLOW_HEADERS",
      "CORS_ALLOW_CREDENTIALS",
      "LLM_PROVIDER",
      "OPENAI_MODEL",
      "OPENROUTER_MODEL",
      "OAUTH_REDIRECT_BASE_URL",
      "GOOGLE_CLIENT_ID",
      "GOOGLE_AUTH_REDIRECT_URI",
      "GOOGLE_REDIRECT_URI",
      "META_CLIENT_ID",
      "META_APP_ID",
      "META_REDIRECT_URI",
      "INSTAGRAM_CONFIG_ID",
      "TIKTOK_CLIENT_KEY",
      "PINTEREST_APP_ID",
      "NEXT_PUBLIC_API_BASE_URL",
      "NEXT_PUBLIC_CREATOR_USER_ID"
    ]
  }
}
