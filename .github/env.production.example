# Production overrides for Vercel
# Copy to .github/env.production.local (gitignored) before sync scripts

ENVIRONMENT=production
AUTH_URL=https://creator-os-gold.vercel.app
CORS_ALLOW_ORIGINS=https://creator-os-gold.vercel.app
OAUTH_REDIRECT_BASE_URL=https://creator-os-gold.vercel.app/api/v1/integrations/oauth
GOOGLE_AUTH_REDIRECT_URI=https://creator-os-gold.vercel.app/api/v1/auth/google/callback
META_REDIRECT_URI=https://creator-os-gold.vercel.app/api/v1/social/instagram/callback
NEXT_PUBLIC_API_BASE_URL=/api/v1
LLM_PROVIDER=mock
