# Production overrides applied when running scripts/sync-github-env.sh
# Copy to env.production.local and set your production URLs.
#
#   cp .github/env.production.example .github/env.production.local
#
# AUTH_URL=https://your-app.vercel.app
# CORS_ALLOW_ORIGINS=https://your-app.vercel.app
# OAUTH_REDIRECT_BASE_URL=https://your-app.vercel.app/api/v1/integrations/oauth
# GOOGLE_AUTH_REDIRECT_URI=https://your-app.vercel.app/api/v1/auth/google/callback
# META_REDIRECT_URI=https://your-app.vercel.app/api/v1/social/instagram/callback
# LLM_PROVIDER=mock
