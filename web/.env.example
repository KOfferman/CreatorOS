# CreatorOS web (Next.js)
#
# Copy for local development:
#   cp web/.env.example web/.env.local
#
# Production (Vercel): set in dashboard or sync via ./scripts/sync-github-env.sh
# NEXT_PUBLIC_* vars are embedded at build time.

# =============================================================================
# Local development (API on port 8000)
# =============================================================================
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# Demo seed user — must match docs/seed_data.sql (daniela@creatoros.demo)
NEXT_PUBLIC_CREATOR_USER_ID=10000000-0000-4000-8000-000000000001

# =============================================================================
# Production (Vercel Services — same-origin API)
# =============================================================================
# NEXT_PUBLIC_API_BASE_URL=/api/v1
# NEXT_PUBLIC_CREATOR_USER_ID=10000000-0000-4000-8000-000000000001
