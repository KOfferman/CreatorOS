{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "services": {
    "web": {
      "root": "web",
      "framework": "nextjs",
      "installCommand": "corepack enable && pnpm install --frozen-lockfile",
      "buildCommand": "NEXT_PUBLIC_API_BASE_URL=/api/v1 pnpm build"
    },
    "api": {
      "root": "api",
      "framework": "fastapi",
      "entrypoint": "app.main:app",
      "installCommand": "bash scripts/vercel-install.sh",
      "functions": {
        "app/main.py": {
          "maxDuration": 60,
          "excludeFiles": "{tests/**,worker/**,**/__pycache__/**,**/*.pyc,.venv/**,**/.pytest_cache/**}",
          "includeFiles": "{../shared/ai_core/**,../shared/agents/**,../shared/database/**,../shared/shared/**}"
        }
      }
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": { "service": "api" } },
    { "source": "/health", "destination": { "service": "api" } },
    { "source": "/healthz", "destination": { "service": "api" } },
    { "source": "/(.*)", "destination": { "service": "web" } }
  ]
}
