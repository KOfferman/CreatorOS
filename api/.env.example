# CreatorOS environment variables
#
# Copy to api/.env.local for local development (recommended):
#   cp api/.env.example api/.env.local
#
# Copy to api/.env for Docker Compose:
#   cp api/.env.example api/.env
#
# Sync to GitHub Actions (repository secrets/variables):
#   ./scripts/sync-github-env.sh --repo YOUR_ORG/CreatorOS
#
# See docs/DEPLOYMENT.md for Vercel + GitHub CI/CD setup.

# =============================================================================
# Core
# =============================================================================
ENVIRONMENT=development
LOG_LEVEL=INFO

# Required — min 24 characters (generate: openssl rand -base64 32)
AUTH_SECRET=local-dev-secret-change-in-production-32
AUTH_URL=http://localhost:3000
AUTH_ENABLED=true
AUTH_JWT_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_EXP_MINUTES=60
API_RATE_LIMIT_PER_MINUTE=120

# CORS (comma-separated origins; use production URL on Vercel)
CORS_ALLOW_ORIGINS=http://localhost:3000
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*
CORS_ALLOW_CREDENTIALS=true

# =============================================================================
# Database
# =============================================================================
# Docker Compose (default below) — or use remote MySQL for local dev:
# DATABASE_URL=mysql+pymysql://user:pass@host:3306/dbname

MYSQL_ROOT_PASSWORD=creatoros_root
MYSQL_USER=creatoros
MYSQL_PASSWORD=creatoros
MYSQL_DATABASE=creatoros
MYSQL_HOST=mysql
MYSQL_PORT=3306
DATABASE_URL=mysql+pymysql://creatoros:creatoros@mysql:3306/creatoros

# =============================================================================
# Redis / Celery
# =============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_ENABLE_BEAT=false
SYSTEM_USER_EMAIL=system@creatoros.local
SYSTEM_USER_NAME=CreatorOS System

# =============================================================================
# AI — Growth Coach (LLM_PROVIDER)
# Options: mock | openai | openrouter | openclaw | hermes
# =============================================================================
# Local dev (zero cost): mock
# Local Hermes: hermes + Ollama (cd api && make dev)
# Vercel/production: mock or openai — do NOT use hermes (no local Ollama)

LLM_PROVIDER=mock

# OpenAI (LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# OpenClaw gateway (LLM_PROVIDER=openclaw)
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_MODEL=openclaw/default

# Hermes via local Ollama (LLM_PROVIDER=hermes)
# Setup: brew install ollama && ollama pull hermes3
# Run:   cd api && make dev
# Docker: docker compose --profile hermes up  (uses http://ollama:11434)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=hermes3

# Hermes via OpenRouter (LLM_PROVIDER=openrouter)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=nousresearch/hermes-3-llama-3.1-70b

# Optional override for any provider
LLM_MODEL=

# =============================================================================
# App ports (Docker Compose / local)
# =============================================================================
API_PORT=8000
WEB_PORT=3000

# =============================================================================
# Platform OAuth (Settings → Integrations)
# Leave blank to disable; add keys to enable real connections.
# =============================================================================
OAUTH_REDIRECT_BASE_URL=http://localhost:8000/api/v1/integrations/oauth

# Google / YouTube
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_AUTH_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback
# Alias also accepted: GOOGLE_REDIRECT_URI

# Meta / Instagram Business Login
META_CLIENT_ID=
META_CLIENT_SECRET=
META_REDIRECT_URI=http://localhost:8000/api/v1/social/instagram/callback
# Aliases also accepted: META_APP_ID, META_APP_SECRET, INSTAGRAM_REDIRECT_URI
INSTAGRAM_CONFIG_ID=

# TikTok
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# Pinterest
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=

# =============================================================================
# Vercel / GitHub Actions (production overrides — see .github/env.production.example)
# =============================================================================
# ENVIRONMENT=production
# AUTH_URL=https://your-app.vercel.app
# CORS_ALLOW_ORIGINS=https://your-app.vercel.app
# LLM_PROVIDER=mock
# OAUTH_REDIRECT_BASE_URL=https://your-app.vercel.app/api/v1/integrations/oauth
