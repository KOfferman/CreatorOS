# Shared
ENVIRONMENT=development
LOG_LEVEL=INFO
AUTH_SECRET=
AUTH_URL=http://localhost:3000
AUTH_ENABLED=true
AUTH_JWT_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_EXP_MINUTES=60
API_RATE_LIMIT_PER_MINUTE=120
CORS_ALLOW_ORIGINS=http://localhost:3000
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*
CORS_ALLOW_CREDENTIALS=true

# MySQL
MYSQL_ROOT_PASSWORD=creatoros_root
MYSQL_USER=creatoros
MYSQL_PASSWORD=creatoros
MYSQL_DATABASE=creatoros
MYSQL_HOST=mysql
MYSQL_PORT=3306
DATABASE_URL=mysql+pymysql://creatoros:creatoros@mysql:3306/creatoros

# Redis / Celery
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_ENABLE_BEAT=false
SYSTEM_USER_EMAIL=system@creatoros.local
SYSTEM_USER_NAME=CreatorOS System

# AI provider settings
LLM_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# App ports
API_PORT=8000
WEB_PORT=3000

# Platform OAuth (set credentials to enable real connections in Settings)
OAUTH_REDIRECT_BASE_URL=http://localhost:8000/api/v1/integrations/oauth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
META_APP_ID=
META_APP_SECRET=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=
